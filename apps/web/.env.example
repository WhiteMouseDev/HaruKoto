# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# AI Provider (openai | google)
AI_PROVIDER=google
OPENAI_API_KEY=your-openai-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-key

# OAuth 설정 (Supabase 대시보드에서 설정)
# Google: https://console.cloud.google.com/ → OAuth 2.0 Client ID
# Kakao: https://developers.kakao.com/ → REST API Key
# Apple: https://developer.apple.com/ → Service ID
# Redirect URL: https://[project-ref].supabase.co/auth/v1/callback

# Kakao JS SDK (카카오톡 앱 원터치 로그인)
# 카카오 개발자 포털 → 앱 키 확인
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Web Push (VAPID) — 무료, 자체 생성
# 생성: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# PortOne V2 결제
PORTONE_STORE_ID=store-xxx
PORTONE_CHANNEL_KEY=channel-xxx
PORTONE_BILLING_CHANNEL_KEY=channel-xxx
PORTONE_V2_SECRET_KEY=portone_v2_secret_xxx
PORTONE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxx

# GCS (Google Cloud Storage)
GCS_BUCKET_NAME=harukoto-storage
GCS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_GCS_CDN_URL=https://storage.googleapis.com/harukoto-storage

# Vercel Cron 인증
CRON_SECRET=your-cron-secret

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (에러 모니터링)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
