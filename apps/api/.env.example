# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase Auth (JWKS/ES256 — URL만 있으면 자동으로 공개키 가져옴)
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=  # Legacy HS256 폴백 (비워두면 JWKS 사용)

# Google AI
GOOGLE_API_KEY=your-google-api-key

# Google Cloud Storage
GCS_BUCKET_NAME=harukoto-tts
GCS_CDN_BASE_URL=https://storage.googleapis.com/harukoto-tts

# PortOne V2 결제
PORTONE_API_SECRET=your-portone-api-secret
PORTONE_STORE_ID=your-store-id
PORTONE_CHANNEL_KEY=your-channel-key
PORTONE_WEBHOOK_SECRET=your-webhook-secret

# Redis (Rate Limiting)
REDIS_URL=redis://localhost:6379

# VAPID (Web Push)
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_EMAIL=mailto:admin@harukoto.app

# CORS
CORS_ORIGINS=http://localhost:3000,https://harukoto.app

# Cron Secret
CRON_SECRET=your-cron-secret

# Sentry
SENTRY_DSN=

# Environment
ENVIRONMENT=development

# ==========================================
# GitHub Actions Secrets (CI/CD 자동 배포용)
# GitHub 레포 Settings > Secrets and variables > Actions 에 추가
# ==========================================
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_SERVICE_ACCOUNT=123456789-compute@developer.gserviceaccount.com
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/123456789/locations/global/workloadIdentityPools/github-actions/providers/github
