{
  "name": "@harukoto/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:sync": "prisma db pull --schema=prisma/schema.prisma && prisma format --schema=prisma/schema.prisma && prisma generate",
    "db:push": "node ./scripts/block-prisma-ddl.mjs db:push",
    "db:migrate": "node ./scripts/block-prisma-ddl.mjs db:migrate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "vocab:audit:n123": "node scripts/audit-n123-vocabulary.mjs",
    "vocab:review:batch": "node scripts/prepare-vocab-manual-review-batches.mjs",
    "vocab:review:compile": "node scripts/compile-vocab-reviewed-final.mjs",
    "vocab:recorrect:priority": "node scripts/recorrect-priority-vocab-v3.mjs",
    "lessons:validate": "node scripts/validate-lessons.mjs",
    "lessons:quality": "node scripts/lesson-quality-gate.mjs",
    "build": "prisma generate",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@harukoto/config": "workspace:*",
    "@types/node": "^20.19.35",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
