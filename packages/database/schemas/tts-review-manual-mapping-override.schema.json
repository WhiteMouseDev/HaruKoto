{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/tts-review-manual-mapping-override.schema.json",
  "title": "TTS Review Manual Mapping Override",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "decisions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "targetId",
          "topicId",
          "contentType",
          "lookupType",
          "adminField",
          "jlptLevel",
          "decisionStatus",
          "notesKo"
        ],
        "properties": {
          "targetId": {
            "type": "string",
            "pattern": "^tts-[a-z0-9][a-z0-9-]*$"
          },
          "topicId": {
            "type": "string",
            "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
          },
          "contentType": { "enum": ["vocabulary", "grammar"] },
          "lookupType": { "enum": ["vocabulary_level_order", "grammar_level_order"] },
          "adminField": { "type": "string", "minLength": 1 },
          "jlptLevel": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
          "grammarOrder": { "type": "integer", "minimum": 1 },
          "vocabularyOrder": { "type": "integer", "minimum": 1 },
          "contentLabel": { "type": "string", "minLength": 1 },
          "contentReading": { "type": "string", "minLength": 1 },
          "meaningKo": { "type": "string", "minLength": 1 },
          "decisionStatus": { "enum": ["approved"] },
          "notesKo": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": {
              "properties": { "contentType": { "const": "vocabulary" } },
              "required": ["contentType"]
            },
            "then": {
              "properties": {
                "lookupType": { "const": "vocabulary_level_order" }
              },
              "required": [
                "vocabularyOrder",
                "contentLabel",
                "contentReading",
                "meaningKo"
              ]
            }
          },
          {
            "if": {
              "properties": { "contentType": { "const": "grammar" } },
              "required": ["contentType"]
            },
            "then": {
              "properties": {
                "lookupType": { "const": "grammar_level_order" }
              },
              "required": ["grammarOrder"]
            }
          }
        ]
      }
    }
  }
}
