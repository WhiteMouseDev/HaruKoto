{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/curriculum-topic.schema.json",
  "title": "Curriculum Topics",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "topics"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topicId",
          "titleKo",
          "topicType",
          "inferredJlptLevel",
          "coverageStatus",
          "sourceRefs"
        ],
        "properties": {
          "topicId": {
            "type": "string",
            "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
          },
          "titleKo": { "type": "string", "minLength": 1 },
          "canonicalPattern": { "type": "string" },
          "topicType": {
            "enum": [
              "kana",
              "vocabulary",
              "grammar",
              "kanji",
              "conversation",
              "reading",
              "register"
            ]
          },
          "inferredJlptLevel": {
            "enum": [
              "ABSOLUTE_ZERO",
              "N5",
              "N4",
              "N3",
              "N2",
              "N1",
              "CONVERSATION",
              "BUSINESS"
            ]
          },
          "levelConfidence": { "enum": ["low", "medium", "high"] },
          "coverageStatus": {
            "enum": ["covered", "partial", "missing", "deferred"]
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "ref"],
              "properties": {
                "type": { "enum": ["pdf", "internal", "public_dataset"] },
                "ref": { "type": "string", "minLength": 1 }
              }
            }
          },
          "mappedGrammarOrders": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "order"],
              "properties": {
                "level": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
                "order": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "mappedLessonIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "prerequisiteTopicIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "contrastTopicIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "audioPolicy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ttsTargets": {
                "type": "array",
                "items": {
                  "enum": [
                    "word",
                    "reading",
                    "japanese",
                    "pattern",
                    "example_sentence",
                    "script_line",
                    "question_prompt"
                  ]
                }
              },
              "defaultSpeed": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
              "requiredBeforePublish": { "type": "boolean" },
              "preferredVoiceId": { "type": "string" },
              "audioTargetType": {
                "enum": [
                  "vocabulary",
                  "grammar",
                  "kana",
                  "lesson_script",
                  "example_sentence",
                  "question_prompt"
                ]
              }
            }
          },
          "reviewStatus": {
            "enum": ["needs_review", "approved", "rejected"]
          },
          "notesKo": { "type": "string" }
        }
      }
    }
  }
}
