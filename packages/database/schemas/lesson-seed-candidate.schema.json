{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/lesson-seed-candidate.schema.json",
  "title": "Lesson Seed Candidates",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "candidates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidateId",
          "status",
          "lessonBlueprintId",
          "sourceTopicIds",
          "exampleIds",
          "promotionTarget",
          "seedShape",
          "validationGates",
          "notesKo"
        ],
        "properties": {
          "candidateId": {
            "type": "string",
            "pattern": "^lsc-[a-z0-9][a-z0-9-]*$"
          },
          "status": { "enum": ["draft", "review", "approved"] },
          "lessonBlueprintId": {
            "type": "string",
            "pattern": "^ldb-[a-z0-9][a-z0-9-]*$"
          },
          "sourceTopicIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
            }
          },
          "exampleIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ex-[a-z0-9][a-z0-9-]*$"
            }
          },
          "promotionTarget": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "level",
              "partNo",
              "chapterNo",
              "lessonNo",
              "chapterLessonNo",
              "publishStatus"
            ],
            "properties": {
              "level": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
              "partNo": { "type": "integer", "minimum": 1 },
              "chapterNo": { "type": "integer", "minimum": 1 },
              "lessonNo": { "type": "integer", "minimum": 1 },
              "chapterLessonNo": { "type": "integer", "minimum": 1 },
              "publishStatus": { "const": "DRAFT" }
            }
          },
          "seedShape": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "title",
              "subtitle",
              "topic",
              "estimated_minutes",
              "grammar",
              "vocab_orders",
              "content_jsonb"
            ],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "subtitle": { "type": "string", "minLength": 1 },
              "topic": { "type": "string", "minLength": 1 },
              "estimated_minutes": { "type": "integer", "minimum": 1 },
              "grammar": {
                "type": "object",
                "additionalProperties": false,
                "required": ["level", "grammar_order", "pattern", "meaning_ko"],
                "properties": {
                  "level": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
                  "grammar_order": { "type": "integer", "minimum": 1 },
                  "pattern": { "type": "string", "minLength": 1 },
                  "meaning_ko": { "type": "string", "minLength": 1 },
                  "supporting_grammar_orders": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 1 }
                  }
                }
              },
              "vocab_orders": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "integer", "minimum": 1 }
              },
              "content_jsonb": {
                "type": "object",
                "additionalProperties": false,
                "required": ["reading", "questions"],
                "properties": {
                  "reading": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["type", "scene", "script", "highlights"],
                    "properties": {
                      "type": { "enum": ["dialogue", "narrative"] },
                      "scene": { "type": "string", "minLength": 1 },
                      "script": {
                        "type": "array",
                        "minItems": 3,
                        "maxItems": 6,
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["speaker", "voice_id", "text", "translation"],
                          "properties": {
                            "speaker": { "type": "string", "minLength": 1 },
                            "voice_id": { "type": "string", "minLength": 1 },
                            "text": { "type": "string", "minLength": 1 },
                            "translation": { "type": "string", "minLength": 1 }
                          }
                        }
                      },
                      "highlights": {
                        "type": "array",
                        "minItems": 1,
                        "items": { "type": "string", "minLength": 1 }
                      }
                    }
                  },
                  "questions": {
                    "type": "array",
                    "minItems": 5,
                    "items": {
                      "type": "object",
                      "additionalProperties": true,
                      "required": ["order", "type", "prompt", "explanation"],
                      "properties": {
                        "order": { "type": "integer", "minimum": 1 },
                        "type": {
                          "enum": ["VOCAB_MCQ", "CONTEXT_CLOZE", "SENTENCE_REORDER"]
                        },
                        "prompt": { "type": "string", "minLength": 1 },
                        "explanation": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            }
          },
          "validationGates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "ExampleOriginalityGate",
                "RuntimeQuestionCompatibilityGate",
                "AudioReadinessGate",
                "KoreanLearnerGate",
                "RegisterGate",
                "ContrastGate"
              ]
            }
          },
          "notesKo": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
