{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/topic-grammar-map.schema.json",
  "title": "Topic Grammar Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "mappings"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topicId", "grammarLevel", "grammarOrder", "matchType"],
        "properties": {
          "topicId": {
            "type": "string",
            "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
          },
          "grammarLevel": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
          "grammarOrder": { "type": "integer", "minimum": 1 },
          "matchType": { "enum": ["exact", "partial", "related"] },
          "notesKo": { "type": "string" }
        }
      }
    }
  }
}
