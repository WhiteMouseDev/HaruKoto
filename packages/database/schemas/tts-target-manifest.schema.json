{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/tts-target-manifest.schema.json",
  "title": "TTS Target Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "targets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
          "required": [
            "targetId",
            "topicId",
            "audioTargetType",
            "audioField",
            "textSource",
            "defaultSpeed",
            "requiredBeforePublish",
            "generationStatus",
            "cacheKeyStrategy"
          ],
        "properties": {
          "targetId": {
            "type": "string",
            "pattern": "^tts-[a-z0-9][a-z0-9-]*$"
          },
          "topicId": {
            "type": "string",
            "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
          },
          "audioTargetType": {
            "enum": [
              "vocabulary",
              "grammar",
              "kana",
              "lesson_script",
              "example_sentence",
              "question_prompt"
            ]
          },
          "audioField": {
            "enum": [
              "word",
              "reading",
              "japanese",
              "pattern",
              "example_sentence",
              "script_line",
              "question_prompt"
            ]
          },
          "textSource": { "type": "string", "minLength": 1 },
          "defaultSpeed": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
          "requiredBeforePublish": { "type": "boolean" },
          "preferredVoiceId": { "type": "string" },
          "generationStatus": {
            "enum": ["missing", "generated", "approved", "rejected", "stale"]
          },
          "cacheKeyStrategy": {
            "enum": ["provider-model-speed-field-text-hash-v1"]
          },
          "notesKo": { "type": "string" }
        }
      }
    }
  }
}
