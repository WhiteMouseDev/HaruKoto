{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/pdf-topic-inventory.schema.json",
  "title": "PDF Topic Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "status", "items"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "source": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pdfRef",
          "titleKo",
          "topicCandidates",
          "inferredLevels",
          "coverageAction"
        ],
        "properties": {
          "pdfRef": { "type": "string", "pattern": "^\\d{3}$" },
          "titleKo": { "type": "string", "minLength": 1 },
          "topicCandidates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "inferredLevels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "ABSOLUTE_ZERO",
                "N5",
                "N4",
                "N3",
                "N2",
                "N1",
                "CONVERSATION",
                "BUSINESS"
              ]
            }
          },
          "levelConfidence": { "enum": ["low", "medium", "high"] },
          "coverageAction": {
            "enum": ["map_existing", "create_topic", "split_topic", "defer"]
          },
          "notesKo": { "type": "string" }
        }
      }
    }
  }
}
