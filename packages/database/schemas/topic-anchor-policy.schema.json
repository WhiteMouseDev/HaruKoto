{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harukoto.local/schemas/topic-anchor-policy.schema.json",
  "title": "Topic Anchor Policies",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "policies"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["draft", "review", "approved"] },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policyId",
          "status",
          "topicId",
          "route",
          "targetLessonBlueprintId",
          "exampleIds",
          "recommendedWave",
          "priority",
          "anchorDecision",
          "promotionReadiness",
          "notesKo"
        ],
        "properties": {
          "policyId": {
            "type": "string",
            "pattern": "^anchor-[a-z0-9][a-z0-9-]*$"
          },
          "status": { "enum": ["draft", "review", "approved"] },
          "topicId": {
            "type": "string",
            "pattern": "^topic-[a-z0-9][a-z0-9-]*$"
          },
          "route": {
            "enum": [
              "scaffold_candidate",
              "vocab_skill_candidate",
              "new_grammar_metadata_v2",
              "split_grammar_metadata_v2"
            ]
          },
          "targetLessonBlueprintId": {
            "type": "string",
            "pattern": "^ldb-[a-z0-9][a-z0-9-]*$"
          },
          "exampleIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ex-[a-z0-9][a-z0-9-]*$"
            }
          },
          "recommendedWave": {
            "enum": [
              "WAVE_1_N5_PATCH",
              "WAVE_2_N4_FOUNDATION",
              "WAVE_3_N3_PLUS",
              "WAVE_4_REGISTER_BUSINESS"
            ]
          },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "anchorDecision": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode",
              "requiresNewGrammarMetadata",
              "requiresScaffoldCandidate",
              "requiresContrastPolicy",
              "existingGrammarRefs",
              "proposedMetadataIds"
            ],
            "properties": {
              "mode": {
                "enum": [
                  "scaffold",
                  "vocabulary_skill",
                  "new_n5_grammar",
                  "split_n5_n4_grammar"
                ]
              },
              "requiresNewGrammarMetadata": { "type": "boolean" },
              "requiresScaffoldCandidate": { "type": "boolean" },
              "requiresContrastPolicy": { "type": "boolean" },
              "existingGrammarRefs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["level", "order"],
                  "properties": {
                    "level": { "enum": ["N5", "N4", "N3", "N2", "N1"] },
                    "order": { "type": "integer", "minimum": 1 }
                  }
                }
              },
              "proposedMetadataIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^gmv2-[a-z0-9][a-z0-9-]*$"
                }
              },
              "scaffoldCandidateId": {
                "type": "string",
                "pattern": "^scaf-[a-z0-9][a-z0-9-]*$"
              }
            }
          },
          "promotionReadiness": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "requiredBeforeSeedCandidate"],
            "properties": {
              "state": { "enum": ["blocked", "ready_for_candidate", "ready_for_review"] },
              "requiredBeforeSeedCandidate": {
                "type": "array",
                "items": {
                  "enum": [
                    "scaffold_shape_review",
                    "grammar_metadata_v2",
                    "contrast_question_policy",
                    "runtime_question_review",
                    "tts_readiness_review",
                    "human_curriculum_review"
                  ]
                }
              }
            }
          },
          "notesKo": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
