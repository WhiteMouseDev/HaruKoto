generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// Enums
// ==========================================

enum JlptLevel {
  N5
  N4
  N3
  N2
  N1
}

enum PartOfSpeech {
  NOUN
  VERB
  I_ADJECTIVE
  NA_ADJECTIVE
  ADVERB
  PARTICLE
  CONJUNCTION
  COUNTER
  EXPRESSION
  PREFIX
  SUFFIX
}

enum QuizType {
  VOCABULARY
  GRAMMAR
  KANJI
  LISTENING
  KANA
  CLOZE
  SENTENCE_ARRANGE
}

enum KanaType {
  HIRAGANA
  KATAKANA
}

enum ScenarioCategory {
  TRAVEL
  DAILY
  BUSINESS
  FREE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum UserGoal {
  JLPT_N5
  JLPT_N4
  JLPT_N3
  JLPT_N2
  JLPT_N1
  TRAVEL
  BUSINESS
  HOBBY
}

enum WordbookSource {
  QUIZ
  CONVERSATION
  MANUAL
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum ConversationType {
  VOICE
  TEXT
}

// ==========================================
// User & Auth
// ==========================================

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique
  nickname             String?
  avatarUrl            String?   @map("avatar_url")
  jlptLevel            JlptLevel @default(N5) @map("jlpt_level")
  goal                 UserGoal? @map("goal")
  dailyGoal            Int       @default(10) @map("daily_goal")
  experiencePoints     Int       @default(0) @map("experience_points")
  level                Int       @default(1)
  streakCount          Int       @default(0) @map("streak_count")
  longestStreak        Int       @default(0) @map("longest_streak")
  lastStudyDate        DateTime? @map("last_study_date")
  isPremium            Boolean   @default(false) @map("is_premium")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  callSettings         Json?     @default("{}") @map("call_settings")
  showKana             Boolean   @default(false) @map("show_kana")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  quizSessions        QuizSession[]
  conversations       Conversation[]
  achievements        UserAchievement[]
  dailyMissions       DailyMission[]
  wordbook            WordbookEntry[]
  dailyProgress       DailyProgress[]
  vocabProgress       UserVocabProgress[]
  grammarProgress     UserGrammarProgress[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  kanaProgress        UserKanaProgress[]
  kanaStages          UserKanaStage[]
  favoriteCharacters  UserFavoriteCharacter[]
  characterUnlocks    UserCharacterUnlock[]
  subscriptions       Subscription[]
  payments            Payment[]
  dailyAiUsage        DailyAiUsage[]

  @@map("users")
}

// ==========================================
// Content: Vocabulary & Grammar
// ==========================================

model Vocabulary {
  id                 String      @id @default(uuid()) @db.Uuid
  jlptLevel          JlptLevel   @map("jlpt_level")
  word               String
  reading            String
  meaningKo          String      @map("meaning_ko")
  exampleSentence    String?     @map("example_sentence")
  exampleReading     String?     @map("example_reading")
  exampleTranslation String?     @map("example_translation")
  partOfSpeech       PartOfSpeech @map("part_of_speech")
  tags               String[]    @default([])
  audioUrl           String?     @map("audio_url")
  order              Int         @default(0)
  createdAt          DateTime    @default(now()) @map("created_at")

  userProgress UserVocabProgress[]

  @@unique([word, reading, jlptLevel])
  @@index([jlptLevel])
  @@index([partOfSpeech])
  @@map("vocabularies")
}

model Grammar {
  id               String    @id @default(uuid()) @db.Uuid
  jlptLevel        JlptLevel @map("jlpt_level")
  pattern          String
  meaningKo        String    @map("meaning_ko")
  explanation      String
  exampleSentences Json      @default("[]") @map("example_sentences")
  relatedGrammarIds String[] @default([]) @map("related_grammar_ids") @db.Uuid
  order            Int       @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")

  userProgress UserGrammarProgress[]

  @@unique([pattern, jlptLevel])
  @@index([jlptLevel])
  @@map("grammars")
}

// ==========================================
// Quiz System
// ==========================================

model QuizSession {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  quizType      QuizType  @map("quiz_type")
  jlptLevel     JlptLevel @map("jlpt_level")
  totalQuestions Int      @default(0) @map("total_questions")
  correctCount  Int       @default(0) @map("correct_count")
  questionsData Json?     @map("questions_data")
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([userId])
  @@index([userId, jlptLevel])
  @@map("quiz_sessions")
}

model QuizAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String   @map("session_id") @db.Uuid
  questionId       String   @map("question_id") @db.Uuid
  questionType     QuizType @map("question_type")
  selectedOptionId String   @map("selected_option_id")
  isCorrect        Boolean  @map("is_correct")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  answeredAt       DateTime @default(now()) @map("answered_at")

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("quiz_answers")
}

// ==========================================
// Cloze Questions (빈칸 채우기)
// ==========================================

model ClozeQuestion {
  id            String    @id @default(uuid()) @db.Uuid
  sentence      String    // 빈칸({blank}) 포함 문장
  translation   String    // 한국어 번역
  correctAnswer String    @map("correct_answer")
  options       Json      // string[] — 보기 배열
  explanation   String    // 문법 해설
  grammarPoint  String?   @map("grammar_point")
  jlptLevel     JlptLevel @map("jlpt_level")
  difficulty    Int       @default(1) // 1-5
  order         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([sentence, jlptLevel])
  @@index([jlptLevel])
  @@index([jlptLevel, difficulty])
  @@map("cloze_questions")
}

// ==========================================
// Sentence Arrange Questions (어순 배열)
// ==========================================

model SentenceArrangeQuestion {
  id             String    @id @default(uuid()) @db.Uuid
  koreanSentence String    @map("korean_sentence") // 한국어 번역 (프롬프트)
  japaneseSentence String  @map("japanese_sentence") // 정답 일본어 문장
  tokens         Json      // SentenceToken[] — {text, type, meaning, order}
  explanation    String    // 문법 해설
  grammarPoint   String?   @map("grammar_point")
  jlptLevel      JlptLevel @map("jlpt_level")
  difficulty     Int       @default(1) // 1-5
  order          Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([koreanSentence, jlptLevel])
  @@index([jlptLevel])
  @@index([jlptLevel, difficulty])
  @@map("sentence_arrange_questions")
}

// ==========================================
// AI Conversation
// ==========================================

model ConversationScenario {
  id              String           @id @default(uuid()) @db.Uuid
  title           String
  titleJa         String           @map("title_ja")
  description     String
  category        ScenarioCategory
  difficulty      Difficulty
  estimatedMinutes Int             @map("estimated_minutes")
  keyExpressions  String[]         @default([]) @map("key_expressions")
  situation       String
  yourRole        String           @map("your_role")
  aiRole          String           @map("ai_role")
  systemPrompt    String?          @map("system_prompt")
  isActive        Boolean          @default(true) @map("is_active")
  order           Int              @default(0)
  createdAt       DateTime         @default(now()) @map("created_at")

  conversations Conversation[]

  @@unique([title])
  @@index([category])
  @@index([difficulty])
  @@map("conversation_scenarios")
}

model Conversation {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  scenarioId      String?          @map("scenario_id") @db.Uuid
  characterId     String?          @map("character_id") @db.Uuid
  type            ConversationType @default(TEXT)
  messages        Json             @default("[]")
  feedbackSummary Json?            @map("feedback_summary")
  messageCount    Int              @default(0) @map("message_count")
  createdAt       DateTime         @default(now()) @map("created_at")
  endedAt         DateTime?        @map("ended_at")

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario  ConversationScenario? @relation(fields: [scenarioId], references: [id])
  character AiCharacter?          @relation(fields: [characterId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([characterId])
  @@map("conversations")
}

// ==========================================
// Gamification
// ==========================================

model UserAchievement {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  achievementType String   @map("achievement_type")
  achievedAt      DateTime @default(now()) @map("achieved_at")
  metadata        Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementType])
  @@index([userId])
  @@map("user_achievements")
}

model DailyMission {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  date          DateTime @db.Date
  missionType   String   @map("mission_type")
  targetCount   Int      @map("target_count")
  currentCount  Int      @default(0) @map("current_count")
  isCompleted   Boolean  @default(false) @map("is_completed")
  rewardClaimed Boolean  @default(false) @map("reward_claimed")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, missionType])
  @@index([userId, date])
  @@map("daily_missions")
}

model DailyProgress {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  date            DateTime @db.Date
  wordsStudied    Int      @default(0) @map("words_studied")
  quizzesCompleted Int     @default(0) @map("quizzes_completed")
  correctAnswers  Int      @default(0) @map("correct_answers")
  totalAnswers    Int      @default(0) @map("total_answers")
  conversationCount Int    @default(0) @map("conversation_count")
  studyTimeSeconds Int     @default(0) @map("study_time_seconds")
  xpEarned        Int      @default(0) @map("xp_earned")
  kanaLearned     Int      @default(0) @map("kana_learned")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_progress")
}

// ==========================================
// Spaced Repetition (간격 반복 학습)
// ==========================================

model UserVocabProgress {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  vocabularyId   String    @map("vocabulary_id") @db.Uuid
  correctCount   Int       @default(0) @map("correct_count")
  incorrectCount Int       @default(0) @map("incorrect_count")
  streak         Int       @default(0)
  easeFactor     Float     @default(2.5) @map("ease_factor")
  interval       Int       @default(0)
  nextReviewAt   DateTime? @map("next_review_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  mastered       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@index([userId, nextReviewAt])
  @@index([userId, mastered])
  @@map("user_vocab_progress")
}

model UserGrammarProgress {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  grammarId      String    @map("grammar_id") @db.Uuid
  correctCount   Int       @default(0) @map("correct_count")
  incorrectCount Int       @default(0) @map("incorrect_count")
  streak         Int       @default(0)
  easeFactor     Float     @default(2.5) @map("ease_factor")
  interval       Int       @default(0)
  nextReviewAt   DateTime? @map("next_review_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  mastered       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammar Grammar @relation(fields: [grammarId], references: [id], onDelete: Cascade)

  @@unique([userId, grammarId])
  @@index([userId, nextReviewAt])
  @@index([userId, mastered])
  @@map("user_grammar_progress")
}

// ==========================================
// Notifications & Push
// ==========================================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // level_up, streak, achievement
  title     String
  body      String
  emoji     String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ==========================================
// Wordbook (User's Personal Collection)
// ==========================================

model WordbookEntry {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  word      String
  reading   String
  meaningKo String         @map("meaning_ko")
  source    WordbookSource @default(MANUAL)
  note      String?
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
  @@map("wordbook_entries")
}

// ==========================================
// AI Characters (Voice Call)
// ==========================================

model AiCharacter {
  id              String   @id @default(uuid()) @db.Uuid
  name            String          // "하루"
  nameJa          String   @map("name_ja")     // "はる"
  nameRomaji      String   @map("name_romaji") // "Haru"
  gender          String          // "male" | "female"
  ageDescription  String   @map("age_description") // "21세"

  description     String          // "자신감 있고 솔직한 소꿉친구"
  relationship    String          // "소꿉친구", "선생님" 등
  backgroundStory String   @map("background_story")
  personality     String          // 시스템 프롬프트 전체

  voiceName       String   @map("voice_name")   // Gemini voice ID
  voiceBackup     String?  @map("voice_backup")  // 대체 음성 ID

  speechStyle     String   @map("speech_style")  // "casual", "polite", "business", "formal"
  targetLevel     String   @map("target_level")  // "N5~N4", "N4~N3" 등
  silenceMs       Int      @default(1200) @map("silence_ms")

  tier            String   @default("default")   // "default", "beginner", "intermediate", "advanced"
  unlockCondition String?  @map("unlock_condition") // "N4", "N3", "N2", null=기본
  isDefault       Boolean  @default(false) @map("is_default")

  avatarEmoji     String   @map("avatar_emoji")
  avatarUrl       String?  @map("avatar_url")
  gradient        String?

  order           Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  conversations   Conversation[]
  favoritedBy     UserFavoriteCharacter[]
  unlockedBy      UserCharacterUnlock[]

  @@map("ai_characters")
}

// ==========================================
// Kana Learning System
// ==========================================

model KanaCharacter {
  id             String   @id @default(uuid()) @db.Uuid
  kanaType       KanaType @map("kana_type")
  character      String
  romaji         String
  pronunciation  String
  row            String
  column         String
  strokeCount    Int      @map("stroke_count")
  strokeOrder    Json?    @map("stroke_order")
  audioUrl       String?  @map("audio_url")
  exampleWord    String?  @map("example_word")
  exampleReading String?  @map("example_reading")
  exampleMeaning String?  @map("example_meaning")
  category       String   @default("basic")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  userProgress UserKanaProgress[]

  @@unique([kanaType, character])
  @@index([kanaType, row])
  @@index([kanaType, category])
  @@map("kana_characters")
}

model UserKanaProgress {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  kanaId         String    @map("kana_id") @db.Uuid
  correctCount   Int       @default(0) @map("correct_count")
  incorrectCount Int       @default(0) @map("incorrect_count")
  streak         Int       @default(0)
  mastered       Boolean   @default(false)
  lastReviewedAt DateTime? @map("last_reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kana KanaCharacter @relation(fields: [kanaId], references: [id], onDelete: Cascade)

  @@unique([userId, kanaId])
  @@index([userId, mastered])
  @@map("user_kana_progress")
}

model KanaLearningStage {
  id          String   @id @default(uuid()) @db.Uuid
  kanaType    KanaType @map("kana_type")
  stageNumber Int      @map("stage_number")
  title       String
  description String
  characters  String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  userStages UserKanaStage[]

  @@unique([kanaType, stageNumber])
  @@map("kana_learning_stages")
}

model UserKanaStage {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  stageId     String    @map("stage_id") @db.Uuid
  isUnlocked  Boolean   @default(false) @map("is_unlocked")
  isCompleted Boolean   @default(false) @map("is_completed")
  quizScore   Int?      @map("quiz_score")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage KanaLearningStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([userId, stageId])
  @@index([userId])
  @@map("user_kana_stages")
}

// ==========================================
// User Favorite Characters
// ==========================================

model UserFavoriteCharacter {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  characterId String   @map("character_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character AiCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId])
  @@map("user_favorite_characters")
}

// ==========================================
// User Character Unlocks
// ==========================================

model UserCharacterUnlock {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  characterId String   @map("character_id") @db.Uuid
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  character AiCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId])
  @@map("user_character_unlocks")
}

// ==========================================
// Subscription & Payments
// ==========================================

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  billingKey        String?            @map("billing_key")
  portoneCustomerId String?            @map("portone_customer_id")
  currentPeriodStart DateTime          @map("current_period_start")
  currentPeriodEnd   DateTime          @map("current_period_end")
  cancelledAt       DateTime?          @map("cancelled_at")
  cancelReason      String?            @map("cancel_reason")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  subscriptionId   String?       @map("subscription_id") @db.Uuid
  portonePaymentId String?       @unique @map("portone_payment_id")
  amount           Int
  currency         String        @default("KRW")
  status           PaymentStatus @default(PENDING)
  plan             SubscriptionPlan
  failReason       String?       @map("fail_reason")
  paidAt           DateTime?     @map("paid_at")
  refundedAt       DateTime?     @map("refunded_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([portonePaymentId])
  @@map("payments")
}

model DailyAiUsage {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  date           DateTime @db.Date
  chatCount      Int      @default(0) @map("chat_count")
  chatSeconds    Int      @default(0) @map("chat_seconds")
  callCount      Int      @default(0) @map("call_count")
  callSeconds    Int      @default(0) @map("call_seconds")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_ai_usage")
}
